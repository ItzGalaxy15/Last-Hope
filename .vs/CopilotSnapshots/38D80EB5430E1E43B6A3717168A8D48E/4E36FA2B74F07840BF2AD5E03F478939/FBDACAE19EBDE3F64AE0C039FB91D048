using Last_Hope.Engine;
using Microsoft.Xna.Framework;
using Microsoft.Xna.Framework.Graphics;
using Microsoft.Xna.Framework.Input;

namespace Last_Hope;

public class Game1 : Game
{
    private GraphicsDeviceManager _graphics;
    private SpriteBatch _spriteBatch;
    private GameManager _gameManager;
    private BaseWeapon _sword;
    private Vector2 _playerPos;
    private MouseState _previousMouseState;

    public Game1()
    {
        _graphics = new GraphicsDeviceManager(this);
        Content.RootDirectory = "Content";
        IsMouseVisible = true;
    }

    protected override void Initialize()
    {
        _graphics.PreferredBackBufferWidth = 800;
        _graphics.PreferredBackBufferHeight = 600;
        _graphics.ApplyChanges();

        _gameManager = GameManager.GetGameManager();
        _playerPos = new Vector2(400, 300);

        base.Initialize();
    }

    protected override void LoadContent()
    {
        _spriteBatch = new SpriteBatch(GraphicsDevice);
        _gameManager.Load(Content);

        // Create sword with 15 damage and 25% crit chance
        _sword = new Sword("Test Sword", 15, 0.25f);

        base.LoadContent();
    }

    protected override void Update(GameTime gameTime)
    {
        if (GamePad.GetState(PlayerIndex.One).Buttons.Back == ButtonState.Pressed || Keyboard.GetState().IsKeyDown(Keys.Escape))
            Exit();

        var mouseState = Mouse.GetState();

        // Check for mouse click
        if (mouseState.LeftButton == ButtonState.Pressed && _previousMouseState.LeftButton == ButtonState.Released)
        {
            // Get direction from player to mouse
            Vector2 mousePos = mouseState.Position.ToVector2();
            Vector2 direction = mousePos - _playerPos;
            direction.Normalize();

            // Slash in that direction
            _sword.Slash(direction, _playerPos);
        }

        _previousMouseState = mouseState;
        _gameManager.Update(gameTime);

        base.Update(gameTime);
    }

    protected override void Draw(GameTime gameTime)
    {
        GraphicsDevice.Clear(Color.CornflowerBlue);

        _spriteBatch.Begin();

        // Draw player placeholder (white square)
        Texture2D pixelTexture = new Texture2D(GraphicsDevice, 1, 1);
        pixelTexture.SetData(new[] { Color.White });
        _spriteBatch.Draw(pixelTexture, new Rectangle((int)_playerPos.X - 10, (int)_playerPos.Y - 10, 20, 20), Color.Yellow);

        // Draw game objects (slashes)
        _gameManager.Draw(gameTime, _spriteBatch);

        _spriteBatch.End();

        base.Draw(gameTime);
    }
}
