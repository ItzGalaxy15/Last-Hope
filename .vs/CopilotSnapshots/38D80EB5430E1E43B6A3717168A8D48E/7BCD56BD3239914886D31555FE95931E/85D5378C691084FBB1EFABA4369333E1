using Last_Hope.Classes.Weapon;
using Last_Hope.Collision;
using Last_Hope.Engine;
using Microsoft.Xna.Framework;
using System;

namespace Last_Hope;

public class Sword : BaseWeapon
{
    private const float SlashRadius = 100f;  // Distance from player to slash arc
    private const float SlashWidth = 60f;    // Width of each slash segment
    private const int SlashSegments = 12;    // Number of segments in the arc
    private const float ArcAngle = (float)Math.PI * 1.2f;  // ~216 degrees for the arc

    public Sword(string name, int attack, float critChance) : base(name, attack, critChance)
    {
    }

    public override void Slash(Vector2 direction, Vector2 origin)
    {
        // Calculate the starting angle based on direction
        float baseAngle = (float)Math.Atan2(direction.Y, direction.X);
        
        // Create slash segments in an arc
        for (int i = 0; i < SlashSegments; i++)
        {
            // Angle for this segment (spread across the arc)
            float segmentAngle = baseAngle - (ArcAngle / 2f) + (ArcAngle / SlashSegments) * i;
            
            // Position of this segment on the arc
            Vector2 segmentPos = origin + new Vector2(
                (float)Math.Cos(segmentAngle),
                (float)Math.Sin(segmentAngle)
            ) * SlashRadius;
            
            // Direction pointing outward from the arc
            Vector2 segmentDirection = new Vector2(
                (float)Math.Cos(segmentAngle),
                (float)Math.Sin(segmentAngle)
            );
            
            // Create the line piece collider for this segment
            LinePieceCollider linePiece = new LinePieceCollider(segmentPos, segmentDirection, SlashWidth);
            
            // Create and add the slash GameObject
            Slash slash = new Slash(linePiece);
            GameManager.GetGameManager().AddGameObject(slash);
        }
    }
}